LUSTRE_VERSION=2.14.0
LUSTRE_DISTRO_SUFFIX=el8.3
LUSTRE_KERNEL_VERSION=4.18.0-240.1.1.el8_lustre.x86_64

SERVER_INSTANCE=lustre-e2e-server
CLIENT_INSTANCE=lustre-e2e-client

SERVER_TEMPLATE=e2e/lima/templates/lustre-server.yaml
CLIENT_TEMPLATE=e2e/lima/templates/lustre-client.yaml

SERVER_REPO_BASE=https://downloads.whamcloud.com/public/lustre/lustre-2.14.0/el8.3/server
CLIENT_REPO_BASE=https://downloads.whamcloud.com/public/lustre/lustre-2.14.0/el8.3/client
E2FSPROGS_REPO_BASE=https://downloads.whamcloud.com/public/e2fsprogs/1.45.6.wc5/el8

LIMA_NETWORK=user-v2

FS_NAME=lustrefs
MDT_INDEX=0
OST_INDEX=0

SERVER_HOST_ALIAS=lustre-server
CLIENT_HOST_ALIAS=lustre-client

SERVER_MDT_MOUNTPOINT=/srv/lustre/mdt
SERVER_OST_MOUNTPOINT=/srv/lustre/ost
CLIENT_MOUNTPOINT=/mnt/lustre

SERVER_MDT_BLOCK_DEVICE=/dev/vdb
SERVER_OST_BLOCK_DEVICE=/dev/vdc
SERVER_MDT_LOOP_IMAGE=/mnt/lima-mdt/mdt.img
SERVER_OST_LOOP_IMAGE=/mnt/lima-ost/ost.img
SERVER_MDT_LOOP_SIZE_GB=8
SERVER_OST_LOOP_SIZE_GB=16

SERVER_DISK_MDT=mdt
SERVER_DISK_OST=ost
SERVER_DISK_MDT_SIZE=24GiB
SERVER_DISK_OST_SIZE=48GiB
